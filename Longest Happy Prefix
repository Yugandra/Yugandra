class Solution:
    def longestPrefix(self, s: str) -> str:
        n = len(s)
        lps = [0] * n
        
        # Standard KMP preprocessing to build the LPS table
        for i in range(1, n):
            j = lps[i - 1]
            while j > 0 and s[i] != s[j]:
                j = lps[j - 1]
            if s[i] == s[j]:
                j += 1
            lps[i] = j
            
        # The last value in the LPS array gives the length of the 
        # longest proper prefix that is also a suffix.
        return s[:lps[-1]]

import bisect

class RangeModule:
    def __init__(self):
        # track contains sorted boundary points. 
        # Even indices are starts, odd indices are ends.
        self.track = []

    def addRange(self, left: int, right: int) -> None:
        # Find where the new range starts and ends relative to existing boundaries
        i = bisect.bisect_left(self.track, left)
        j = bisect.bisect_right(self.track, right)
        
        # New boundaries to insert (if they aren't already covered)
        sub = []
        if i % 2 == 0: sub.append(left)
        if j % 2 == 0: sub.append(right)
            
        # Replace everything between i and j with the consolidated range
        self.track[i:j] = sub

    def queryRange(self, left: int, right: int) -> bool:
        # Find position of left and right
        i = bisect.bisect_right(self.track, left)
        j = bisect.bisect_left(self.track, right)
        # Condition: left must be inside a range (odd index) 
        # and right must be before the same range ends (i == j)
        return i == j and i % 2 == 1

    def removeRange(self, left: int, right: int) -> None:
        i = bisect.bisect_left(self.track, left)
        j = bisect.bisect_right(self.track, right)
        
        sub = []
        if i % 2 == 1: sub.append(left)
        if j % 2 == 1: sub.append(right)
            
        self.track[i:j] = sub
